#include <iostream>
#include <string>
#include <vector>

using namespace std;


class ListaObecnosci {
private:
    string* nazwa;
    bool* obecny;

public:
    ListaObecnosci(string n) {
        nazwa = new string(n);
        obecny = new bool(false);
    }

    ListaObecnosci(const ListaObecnosci& other) {
        nazwa = new string(*other.nazwa);
        obecny = new bool(*other.obecny);
    }

    ListaObecnosci& operator=(const ListaObecnosci& other) {
        if (this != &other) {
            *nazwa = *other.nazwa;
            *obecny = *other.obecny;
        }
        return *this;
    }

    ~ListaObecnosci() {
        delete nazwa;
        delete obecny;
    }

    void ustawObecnosc(bool status) {
        *obecny = status;
    }

    string getNazwa() const {
        return *nazwa;
    }

    bool getObecnosc() const {
        return *obecny;
    }
};


class Drukarka {
public:
    static void drukujNaglowek(const string& tytul) {
        cout << "\n========== " << tytul << " ==========\n";
    }

    static void drukujOsobe(const string& imie, const string& nazwisko,
                             const string& dataUrodzenia, float wzrost,
                             const vector<ListaObecnosci*>& listy) {
        cout << "Imie: " << imie << " | Nazwisko: " << nazwisko << endl;
        cout << "Data urodzenia: " << dataUrodzenia << " | Wzrost: " << wzrost << " cm\n";
        if (listy.empty()) {
            cout << "  Brak list obecnosci.\n";
        } else {
            for (const auto& l : listy) {
                cout << "  Lista [" << l->getNazwa() << "]: "
                     << (l->getObecnosc() ? "Obecny" : "Nieobecny") << "\n";
            }
        }
    }

    static void drukujStudenta(const string& imie, const string& nazwisko,
                                int indeks, const string& dataUrodzenia, float wzrost,
                                const vector<ListaObecnosci*>& listy) {
        drukujNaglowek("STUDENT");
        cout << "Indeks: " << indeks << "\n";
        drukujOsobe(imie, nazwisko, dataUrodzenia, wzrost, listy);
    }

    static void drukujPracownika(const string& imie, const string& nazwisko,
                                  int id, const string& dataUrodzenia, float wzrost,
                                  const vector<ListaObecnosci*>& listy) {
        drukujNaglowek("PRACOWNIK");
        cout << "ID: " << id << "\n";
        drukujOsobe(imie, nazwisko, dataUrodzenia, wzrost, listy);
    }
};


class Osoba {
protected:
    string imie;
    string nazwisko;
    string data_urodzenia;
    float wzrost;
    vector<ListaObecnosci*> listy;

public:
    Osoba() : wzrost(0.0f) {}

    virtual ~Osoba() {
        for (auto l : listy) {
            delete l;
        }
    }

    virtual void ustaw() {
        cout << "Imie: ";
        cin >> imie;
        cout << "Nazwisko: ";
        cin >> nazwisko;
        cout << "Data urodzenia: ";
        cin >> data_urodzenia;
        cout << "Wzrost: ";
        cin >> wzrost;
    }

    virtual void edytuj() {
        cout << "Nowe imie: ";
        cin >> imie;
        cout << "Nowe nazwisko: ";
        cin >> nazwisko;
        cout << "Nowa data urodzenia: ";
        cin >> data_urodzenia;
        cout << "Nowy wzrost: ";
        cin >> wzrost;
    }

    virtual void wyswietl() const = 0;

    void dodajListe(const string& nazwa) {
        listy.push_back(new ListaObecnosci(nazwa));
    }

    void ustawObecnosc(const string& nazwa) {
        for (auto& l : listy) {
            if (l->getNazwa() == nazwa) {
                bool status;
                cout << "Obecny (1/0): ";
                cin >> status;
                l->ustawObecnosc(status);
                return;
            }
        }
        cout << "Nie ma takiej listy!\n";
    }

    string getNazwisko() const {
        return nazwisko;
    }

    virtual string getTyp() const = 0;
};


class Student : public Osoba {
private:
    int indeks;

public:
    Student() : indeks(0) {}

    void ustaw() override {
        Osoba::ustaw();
        cout << "Indeks: ";
        cin >> indeks;
    }

    void edytuj() override {
        Osoba::edytuj();
        cout << "Nowy indeks: ";
        cin >> indeks;
    }

    void wyswietl() const override {
        Drukarka::drukujStudenta(imie, nazwisko, indeks, data_urodzenia, wzrost, listy);
    }

    string getTyp() const override {
        return "Student";
    }
};


class Pracownik : public Osoba {
private:
    int id;

public:
    Pracownik() : id(0) {}

    void ustaw() override {
        Osoba::ustaw();
        cout << "ID pracownika: ";
        cin >> id;
    }

    void edytuj() override {
        Osoba::edytuj();
        cout << "Nowe ID pracownika: ";
        cin >> id;
    }

    void wyswietl() const override {
        Drukarka::drukujPracownika(imie, nazwisko, id, data_urodzenia, wzrost, listy);
    }

    string getTyp() const override {
        return "Pracownik";
    }
};


class Interfejs {
private:
    vector<Osoba*> osoby;

public:
    ~Interfejs() {
        for (auto o : osoby) {
            delete o;
        }
    }

    void uruchom() {
        int wybor;
        string nazwisko, nazwaListy;

        do {
            cout << "\n1. Dodaj studenta\n";
            cout << "2. Dodaj pracownika\n";
            cout << "3. Dodaj liste obecnosci (dla wszystkich)\n";
            cout << "4. Ustaw obecnosc\n";
            cout << "5. Wyswietl wszystkich\n";
            cout << "6. Edytuj dane\n";
            cout << "7. Usun osobe\n";
            cout << "0. Wyjscie\n";
            cout << "Wybor: ";
            cin >> wybor;

            switch (wybor) {

            case 1: {
                Osoba* o = new Student();
                o->ustaw();
                osoby.push_back(o);
                cout << "Dodano studenta.\n";
                break;
            }

            case 2: {
                Osoba* o = new Pracownik();
                o->ustaw();
                osoby.push_back(o);
                cout << "Dodano pracownika.\n";
                break;
            }

            case 3: {
                cout << "Podaj nazwe listy: ";
                cin >> nazwaListy;
                for (auto o : osoby) {
                    o->dodajListe(nazwaListy);
                }
                cout << "Dodano liste \"" << nazwaListy << "\" dla wszystkich.\n";
                break;
            }

            case 4: {
                cout << "Nazwisko: ";
                cin >> nazwisko;
                cout << "Lista: ";
                cin >> nazwaListy;
                for (auto o : osoby) {
                    if (o->getNazwisko() == nazwisko) {
                        o->ustawObecnosc(nazwaListy);
                    }
                }
                break;
            }

            case 5: {
                if (osoby.empty()) {
                    cout << "Brak osob na liscie.\n";
                } else {
                    for (auto o : osoby) {
                        o->wyswietl();
                    }
                }
                break;
            }

            case 6: {
                cout << "Nazwisko: ";
                cin >> nazwisko;
                for (auto o : osoby) {
                    if (o->getNazwisko() == nazwisko) {
                        o->edytuj();
                        cout << "Zaktualizowano.\n";
                    }
                }
                break;
            }

            case 7: {
                cout << "Nazwisko: ";
                cin >> nazwisko;
                for (int i = 0; i < (int)osoby.size(); i++) {
                    if (osoby[i]->getNazwisko() == nazwisko) {
                        delete osoby[i];
                        osoby.erase(osoby.begin() + i);
                        cout << "Usunieto.\n";
                        break;
                    }
                }
                break;
            }

            case 0:
                cout << "Do widzenia!\n";
                break;

            default:
                cout << "Nieprawidlowy wybor.\n";
            }

        } while (wybor != 0);
    }
};


int main() {
    Interfejs app;
    app.uruchom();
    return 0;
}
